# =============================================================================
# Pitchwright — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# All secrets are server-side only. None of these are exposed to the browser
# (NEXT_PUBLIC_ prefix is intentionally absent from all sensitive values).
# =============================================================================

# --- Clerk (Authentication) ---
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Clerk redirect URLs (adjust for your domain in production)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Supabase ---
# Get these from https://supabase.com → your project → Settings → API
# NEXT_PUBLIC_SUPABASE_URL is safe to expose (it's just the project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon key is safe to expose — RLS is your real security layer
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJREPLACE_ME
# Service role key MUST stay server-side only — bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=eyJREPLACE_ME

# --- Anthropic (AI Generation) ---
# Get from https://console.anthropic.com → API Keys
# NEVER prefix with NEXT_PUBLIC_ — must stay server-side only
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Upstash Redis (Rate Limiting) ---
# Get from https://console.upstash.com → your Redis database
# Used for distributed rate limiting across Vercel edge functions
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# --- Resend (Transactional Email) ---
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=notifications@yourdomain.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to sign public proposal share tokens (use a random 32+ char string)
PROPOSAL_TOKEN_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# =============================================================================
# Production checklist reminder:
# [ ] All values above set in Vercel environment variables (not committed)
# [ ] PROPOSAL_TOKEN_SECRET is a cryptographically random string
# [ ] SUPABASE_SERVICE_ROLE_KEY is restricted to server-side routes only
# [ ] ANTHROPIC_API_KEY is restricted to server-side routes only
# =============================================================================
